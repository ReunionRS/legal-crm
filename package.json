{
  "name": "testov",
  "version": "1.0.0",
  "private": true,
  "description": "Legal CRM workspace",
  "scripts": {
    "dev": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "dev:all": "concurrently \"npm run dev --prefix client\" \"npm run dev --prefix server\"",
    "build": "npm run build --prefix client",
    "server:generate": "npm run prisma:generate --prefix server",
    "server:migrate": "npm run prisma:migrate --prefix server",
    "server:seed": "npm run db:seed --prefix server"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
